        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "9262",
          "first_pkg": "552"
        },
        "text": "Let this be quieter than a practice and more like company at the end of a long day.",
        "output_file": "segment_003.wav",
        "pause_after_ms": 9200
      },
      {
        "index": 4,
        "reqid": "a25c18cd89c0985bcf826b696d35f702",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "6885",
          "first_pkg": "552"
        },
        "text": "There is nothing you need to prepare before rest is allowed to begin.",
