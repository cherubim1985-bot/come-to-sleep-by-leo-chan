        "pause_after_ms": 9000
      },
      {
        "index": 5,
        "reqid": "70d887831a602c1f705e812cf38bc329",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "15113",
          "first_pkg": "441"
        },
        "text": "Feel the surface beneath you taking the weight of your head, your shoulders, your back, your hips, and your legs.",
        "output_file": "segment_005.wav",
        "pause_after_ms": 9000
      },
      {
        "index": 6,
        "reqid": "b4c5418c86e9659e98ec225765103346",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "22609",
          "first_pkg": "551"
        },
        "text": "Feel the body resting as if the night air has finally reached you, and let each exhale be a small step through that gate into something simpler, quieter, and unforced.",
        "output_file": "segment_006.wav",
        "pause_after_ms": 9800
      },
      {
        "index": 7,
        "reqid": "e3a63c76186d3db73939c0bd5fd09c18",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "16942",
          "first_pkg": "441"
        },
        "text": "Let the throat be easy. Let the chest stop bracing. Let the belly loosen the way it does when you finally know you are alone and safe.",
        "output_file": "segment_007.wav",
        "pause_after_ms": 9600
      },
      {
        "index": 8,
        "reqid": "69a8fe887c0f8787155a263ac887d8ae",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "12293",
          "first_pkg": "552"
        },
        "text": "The tiny muscles around the eyes can soften now. The jaw can soften. The tongue can rest.",
        "output_file": "segment_008.wav",
        "pause_after_ms": 9600
      },
      {
        "index": 9,
        "reqid": "e0d4495f7cbdc645c69a3cd0c2189de2",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "8258",
          "first_pkg": "663"
        },
        "text": "You do not have to do this well tonight. You only have to let yourself be here.",
