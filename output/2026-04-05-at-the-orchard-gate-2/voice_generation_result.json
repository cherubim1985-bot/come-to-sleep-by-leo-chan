        "pause_after_ms": 10200
      },
      {
        "index": 10,
        "reqid": "50c453523facf8bb739a0d70eafd9aec",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "13410",
          "first_pkg": "551"
        },
        "text": "You do not need a technique to impress anyone here. A soft breath is enough. A longer exhale is enough.",
        "output_file": "segment_010.wav",
        "pause_after_ms": 11200
      },
      {
        "index": 11,
        "reqid": "774ab3743fd3e121bc8bf5b80d8c17c9",
        "code": 3000,
        "message": "Success",
        "addition": {
          "duration": "4892",
          "first_pkg": "552"
        },
        "text": "A restless night can still become a gentle one.",
